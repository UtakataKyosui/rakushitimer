{
  "$schema": "../gen/schemas/android-schema.json",
  "identifier": "android-alarm",
  "description": "Capability for Android alarm management",
  "windows": ["main"],
  "platforms": ["android"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "alarm:allow-set-alarm",
    "alarm:allow-cancel-alarm",
    "alarm:allow-list-alarms",
    "alarm:allow-check-exact-alarm-permission",
    "alarm:allow-open-exact-alarm-settings"
  ]
}
