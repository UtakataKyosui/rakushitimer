{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "いなりといっしょ！",
  "version": "0.1.0",
  "identifier": "com.utakata.rakushitimer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "いなりといっしょ！",
        "width": 800,
        "height": 600,
        "backgroundColor": "#FDFCF5"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "sounds/*": "sounds/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
